#!/usr/bin/env php
<?php

require_once __DIR__ . '/vendor/autoload.php';

define('APP_ROOT', __DIR__);

// Carrega as variáveis de ambiente para conectar no DB
\Core\Utils\Env::load(APP_ROOT . '/.env');

use Core\Console\Migrator;
use Core\Console\Generator;

$command = $argv[1] ?? null;

// --- Comandos de Banco de Dados ---
if ($command === 'init') {
    Migrator::initProject();
    exit;
}

if ($command === 'migrate') {
    $migrator = new Migrator();
    $migrator->applyMigrations();
    exit;
}

if ($command === 'make:migration') {
    $name = $argv[2] ?? null;
    if (!$name) {
        echo "Uso incorreto. Exemplo: php console make:migration nome_da_tabela" . PHP_EOL;
        exit(1);
    }
    $migrator = new Migrator();
    $migrator->makeMigration($name);
    exit;
}

// --- Comandos de Geração de Código ---
if ($command === 'make:test') {
    $name = $argv[2] ?? null;
    if (!$name) {
        echo "Uso incorreto. Exemplo: php console make:test Core/MinhaClasseTest" . PHP_EOL;
        echo "             Ou:       php console make:test App/DTOs/UserDTOTest" . PHP_EOL;
        exit(1);
    }
    Generator::makeTest($name);
    exit;
}

if ($command === 'make:dto') {
    $name = $argv[2] ?? null;
    if (!$name) {
        echo "Uso incorreto. Exemplo: php console make:dto Auth/UserDTO" . PHP_EOL;
        echo "             Ou:       php console make:dto Pedidos/PedidoDTO" . PHP_EOL;
        exit(1);
    }
    Generator::makeDto($name);
    exit;
}

// --- Ajuda ---
echo PHP_EOL;
echo "  🛠️  PHP-MVC-Framework — Comandos disponíveis:" . PHP_EOL;
echo PHP_EOL;
echo "  Banco de Dados:" . PHP_EOL;
echo "    init                         Inicializa o projeto (cria .env, DB e roda migrations)" . PHP_EOL;
echo "    migrate                      Roda as migrations pendentes" . PHP_EOL;
echo "    make:migration <nome>        Cria um novo arquivo de migration em branco" . PHP_EOL;
echo PHP_EOL;
echo "  Geração de Código:" . PHP_EOL;
echo "    make:test <Caminho/NomeTest> Cria um arquivo de Teste Unitário em tests/Unit/" . PHP_EOL;
echo "                                 Ex: php console make:test Core/ValidatorTest" . PHP_EOL;
echo "                                 Ex: php console make:test App/DTOs/UserDTOTest" . PHP_EOL;
echo "    make:dto  <Modulo/NomeDTO>   Cria um arquivo de DTO tipado em app/Modulo/DTOs/" . PHP_EOL;
echo "                                 Ex: php console make:dto Auth/UserDTO" . PHP_EOL;
echo "                                 Ex: php console make:dto Pedidos/PedidoDTO" . PHP_EOL;
echo PHP_EOL;
