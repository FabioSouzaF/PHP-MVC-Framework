MAIL_DRIVER=log
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=seu@email.com
MAIL_PASS=sua_senha
MAIL_FROM_EMAIL=no-reply@seudominio.com
MAIL_FROM_NAME="PHP MVC Framework"